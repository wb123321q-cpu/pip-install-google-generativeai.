# 1. СИСТЕМНЫЙ ПРОМПТ КЛИЕНТА
CLIENT_PROMPT = """
Ты — тренажер для продавцов оптики. Играй роль клиента (возраст 45-60 лет), у которого начинается пресбиопия (плохо видит вблизи), но он сам об этом не знает.
ПРАВИЛА:
1. Выбери случайное имя, возраст (например, 51 год) и профессию (водитель, бухгалтер, программист, учитель, строитель).
2. Твоя базовая жалоба: "Стало тяжело читать мелкий текст в телефоне" или "Устают глаза при работе, размывается текст". Ты пришел за обычными дешевыми очки для чтения.
3. Отвечай коротко (1-3 предложения), как реальный человек. Не используй термины "мультифокальные" или "прогрессивные" линзы сам.
4. Будь немного скептичным. Если тебе предлагают дорогие линзы, возражай: "Почему так дорого?", "Мне проще купить двое очков за 2000р", "Я слышал, от них кружится голова".
5. Соглашайся на покупку МФ линз ТОЛЬКО если доктор:
   - Спросил про твою работу и образ жизни (компьютер, руль, хобби).
   - Выявил, на каких расстояниях ты работаешь.
   - Понятно объяснил, почему МФ линзы заменят тебе несколько очков и дадут плавный фокус.

Начни диалог со своего приветствия и первой базовой жалобы.
"""

# 2. ПРОМПТ ОЦЕНЩИКА (ЭКСПЕРТА)
EVALUATOR_PROMPT = """
Ты — строгий, но поддерживающий бизнес-тренер по продажам в оптике. 
Перед тобой история диалога между доктором (продавцом) и клиентом. 
Проанализируй диалог и составь отчет по следующим пунктам:

1. **Итоговая оценка:** от 1 до 10.
2. **Удачные моменты:** что доктор сделал отлично (вежливость, установление контакта, точные вопросы).
3. **Ошибки и упущения:** выявил ли доктор зрительный профиль? Спросил про профессию, гаджеты, вождение? Объяснил ли ценность мультифокальных линз или сразу назвал высокую цену? Отработал ли возражения?
4. **Вердикт:** Купил в итоге клиент линзы или ушел думать?

Напиши отчет структурировано, понятным языком, без лишней воды.
"""

def start_simulation():
    # Используем flash для быстрой скорости ответов в чате
    model = genai.GenerativeModel(
        model_name="gemini-1.5-flash",
        system_instruction=CLIENT_PROMPT
    )
    
    # Инициализируем чат с памятью
    chat = model.start_chat(history=[])
    
    print("🤖 Симулятор запущен. Для завершения и оценки напишите 'ЗАВЕРШИТЬ'.\n")
    
    # Получаем первую реплику клиента (генерация персонажа)
    response = chat.send_message("Начни симуляцию. Представься.")
    print(f"Клиент: {response.text}\n")
    
    # Игровой цикл диалога
    while True:
        doctor_input = input("Доктор (Вы): ")
        
        if doctor_input.strip().upper() == "ЗАВЕРШИТЬ":
            print("\n=== Диалог завершен. Передаем историю эксперту на оценку... ===")
            break
            
        if not doctor_input.strip():
            continue
            
        # Отправляем реплику доктора ИИ-клиенту
        response = chat.send_message(doctor_input)
        print(f"\nКлиент: {response.text}\n")
        
    # === ЭТАП ОЦЕНКИ ===
    # Вытаскиваем всю историю чата в текстовом формате
    formatted_history = ""
    for message in chat.history:
        role = "Доктор" if message.role == "user" else "Клиент"
        # Исключаем техническую команду старта из финальной истории
        if "Начни симуляцию" in message.parts[0].text:
            continue
        formatted_history += f"{role}: {message.parts[0].text}\n"
    
    # Вызываем модель-оценщика (здесь можно использовать более умную Pro версию)
    evaluator_model = genai.GenerativeModel(model_name="gemini-1.5-pro")
    
    evaluation_request = f"{EVALUATOR_PROMPT}\n\nВот история диалога:\n{formatted_history}"
    eval_response = evaluator_model.generate_content(evaluation_request)
    
    print("\n📊 ОТЧЕТ БИЗНЕС-ТРЕНЕРА:")
    print(eval_response.text)
    
    # Точка отправки в Telegram:
    # Здесь вызовем функцию send_to_telegram(eval_response.text), чтобы отчет улетел руководителю

if __name__ == "__main__":
    start_simulation()
